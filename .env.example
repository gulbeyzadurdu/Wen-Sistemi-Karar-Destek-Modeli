# TimescaleDB (PostgreSQL 15 + TimescaleDB image)
POSTGRES_USER=wen
POSTGRES_PASSWORD=wen_dev
POSTGRES_DB=wen
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://wen:wen_dev@localhost:5432/wen

# Redis
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0

# MQTT (Mosquitto)
MQTT_PORT=1883
MQTT_BROKER_URL=localhost
MQTT_BROKER_PORT=1883

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173

# AI (OpenRouter)
OPENROUTER_API_KEY=your_key_here
AI_MODEL=google/gemini-flash-1.5
